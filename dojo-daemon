#!/usr/bin/env python3
"""
dojo-daemon - Simple CLI wrapper for the Dojo Daemon

Usage:
    ./dojo-daemon start           # Start the daemon
    ./dojo-daemon stop            # Stop the daemon
    ./dojo-daemon status          # Check daemon status
    ./dojo-daemon send "command"  # Send a command
    ./dojo-daemon output          # Get current output
    ./dojo-daemon watch           # Watch output live
"""

